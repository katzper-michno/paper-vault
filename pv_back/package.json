{
  "name": "papervault-back",
  "version": "1.0.0",
  "description": "The backend for papervault",
  "main": "server.js",
  "scripts": {
    "start": "node src/server.ts",
    "dev": "nodemon src/server.ts",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,md}\"",
    "compile": "tsc",
    "compile:check": "tsc --noEmit"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "axios": "^1.13.5",
    "cors": "^2.8.5",
    "dotenv": "^17.2.4",
    "express": "^4.18.2",
    "multer": "^2.1.1",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.3",
    "nodemon": "^3.0.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
